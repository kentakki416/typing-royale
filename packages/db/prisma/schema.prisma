// Jest(CJS環境)で import.meta エラーを回避するため moduleFormat = "cjs" を指定
generator client {
    provider     = "prisma-client"
    output       = "../generated"
    moduleFormat = "cjs"
}

// Data source
datasource db {
    provider = "postgresql"
}

// 認証アカウント（複数プロバイダー対応）
// OAuth プロバイダのアクセストークンは保持しない（docs/spec/github-auth/README.md「アクセストークン非保存方針」）
model AuthAccount {
    id                Int      @id @default(autoincrement())
    userId            Int      @map("user_id")
    /// "google" | "github" | "dev"
    provider          String
    /// プロバイダー側のユーザー ID
    providerAccountId String   @map("provider_account_id")
    createdAt         DateTime @default(now()) @map("created_at")
    updatedAt         DateTime @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@index([userId])
    @@map("auth_accounts")
}

// メモ
model Memo {
    id        Int      @id @default(autoincrement())
    title     String   @db.VarChar(255)
    body      String   @db.Text
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("memos")
}

// ユーザー（認証プロバイダー非依存）
model User {
    id               Int      @id @default(autoincrement())
    /// dev-login や将来のメール連絡用にオプショナルで保持（MVP の GitHub OAuth では収集しない）
    email            String?  @unique
    /// GitHub username 等を初期値に持つ、ユーザー表示用の名前
    displayName      String?  @map("display_name")
    avatarUrl        String?  @map("avatar_url")
    /// false の場合はランキング集計から完全に除外される（順位そのものが計算されない）
    canPublicRanking Boolean  @default(true) @map("can_public_ranking")
    createdAt        DateTime @default(now()) @map("created_at")
    updatedAt        DateTime @updatedAt @map("updated_at")

    accounts AuthAccount[]

    @@map("users")
}
