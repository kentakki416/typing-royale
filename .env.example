# ============================================================================
# typing-royale 環境変数サンプル
# ============================================================================
# このファイルはローカル開発で必要となる環境変数のリファレンスです。
# 実際の値は各アプリの .env.local に設定してください
# （dotenvx で暗号化される運用：`apps/api/CLAUDE.md` の「環境変数の管理」参照）。
#
# 用途別の対応アプリ:
#   - apps/api     : サーバーサイド（Express）
#   - apps/web     : Next.js Web アプリ
#   - apps/admin   : Next.js Admin
#   - apps/mobile  : Expo モバイル
#   - apps/crawler : クローラ + バッチ（Phase 2 以降）
# ============================================================================

# ----------------------------------------------------------------------------
# 共通
# ----------------------------------------------------------------------------
NODE_ENV=local

# ----------------------------------------------------------------------------
# apps/api
# ----------------------------------------------------------------------------
PORT=8080

# Postgres (docker-compose の postgres サービスへ接続)
DATABASE_URL=postgresql://postgres:password@localhost:5432/typing_royale_dev

# Redis (docker-compose の redis サービスへ接続)
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS / フロントエンド URL
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# JWT（本番では必ず安全な値に差し替えること）
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=7d

# GitHub OAuth App (dev 用)
#   - GitHub 上で OAuth App を作成し、Authorization callback URL を
#     http://localhost:3000/api/auth/callback/github に設定する
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/callback/github

# クローラ用 GitHub Personal Access Token
#   - 運営アカウントで発行（スコープは public_repo のみで OK）
GITHUB_PAT=

# Sentry（ローカルは空のまま。Phase 9 で本番 DSN を Secrets Manager / Vercel Env に設定する）
SENTRY_DSN=

# ----------------------------------------------------------------------------
# apps/web (Next.js)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080

# ----------------------------------------------------------------------------
# apps/crawler (Phase 2 以降に使用)
# ----------------------------------------------------------------------------
# 1 回の実行で処理する repo 数。ローンチ初期のブートストラップ時のみ増やす。
CRAWLER_REPOS_PER_RUN=1

# ----------------------------------------------------------------------------
# 広告（Phase 8 で使用。本番 AdSense 取得は Phase 10）
# ----------------------------------------------------------------------------
ADSENSE_PUB_ID=
