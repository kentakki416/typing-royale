{
  "name": "cron",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "crawler:run:typescript": "dotenvx run -f .env.local -- tsx src/task/crawler-run-typescript.ts",
    "crawler:license-recheck": "dotenvx run -f .env.local -- tsx src/task/crawler-license-recheck.ts",
    "batch:ranking": "dotenvx run -f .env.local -- tsx src/task/ranking-batch.ts",
    "dev": "dotenvx run -f .env.local -- tsx watch src/index.ts",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'test/**/*.ts' --fix",
    "start": "dotenvx run -f .env.local -- node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@repo/api-schema": "workspace:^",
    "@repo/db": "workspace:^",
    "@repo/logger": "workspace:^",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:^",
    "@repo/typescript-config": "workspace:^",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
